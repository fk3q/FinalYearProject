# ─── Secrets & environment files ──────────────────────────────────────────────
# Never commit API keys, DB passwords, SMTP creds, etc.
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example

# Common credential / key filenames
*.pem
*.key
*.crt
*.cer
*.pfx
*.p12
secrets/
credentials.json
service-account*.json

# ─── Private app data ─────────────────────────────────────────────────────────
# FAISS vector store contains every user's uploaded document text + embeddings
backend/faiss_store/
faiss_store/
*.faiss
*.index

# User-uploaded files, exports, database dumps, backups
uploads/
user_uploads/
*.sqlite
*.sqlite3
*.db
*.sql.gz
*.dump
*.bak
dump.rdb
mysql_data/

# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
/.pnp
.pnp.js

# Python virtualenvs / caches
venv/
env/
ENV/
.venv/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
htmlcov/

# ─── Build output ─────────────────────────────────────────────────────────────
/build
/dist
dist-ssr
*.local

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/

# ─── Testing ──────────────────────────────────────────────────────────────────
/coverage

# ─── Editor / IDE ─────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ─── OS junk ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
