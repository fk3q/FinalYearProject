# Copy this to .env and fill in your values

# OpenAI Configuration  (required)
OPENAI_API_KEY=sk-...

# FAISS index is stored locally — no external DB needed.

# Application Configuration
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Embedding
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# LLM
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1000

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Retrieval
TOP_K=5

# MySQL — user accounts (create database `course_copilot` or let the SQL file run first)
# Local dev: 127.0.0.1 + your MySQL user. Docker Compose: set MYSQL_HOST=db in compose
# (already set there); optional MYSQL_* overrides live in project root .env for compose.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=course_copilot

# ── Stripe (test mode) ────────────────────────────────────────────────────────
# Leave blank to disable the pricing page / payment routes.
# Dashboard → Developers → API keys. Use test keys (sk_test_... / pk_test_...).
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# From: stripe listen --forward-to localhost:8000/api/payments/webhook
# (the CLI prints `Your webhook signing secret is whsec_...`).
STRIPE_WEBHOOK_SECRET=
# Price IDs from Dashboard → Products. Create two products (Regular, Advanced),
# each with a monthly + yearly recurring price. Copy the `price_...` ids here.
STRIPE_PRICE_REGULAR_MONTHLY=
STRIPE_PRICE_REGULAR_YEARLY=
STRIPE_PRICE_ADVANCED_MONTHLY=
STRIPE_PRICE_ADVANCED_YEARLY=
# Where Stripe redirects after checkout (must match the URL users see in the browser).
FRONTEND_URL=http://localhost:3000

# Google Sign-In — Web Client ID (same string as VITE_GOOGLE_CLIENT_ID in project root .env)
GOOGLE_OAUTH_CLIENT_ID=

# Facebook Login (Meta Developer → your app)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
