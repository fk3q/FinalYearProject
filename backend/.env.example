# Copy this to .env and fill in your values

# OpenAI Configuration  (required)
OPENAI_API_KEY=sk-...

# FAISS index is stored locally — no external DB needed.

# Application Configuration
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Embedding
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# LLM
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1000

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Retrieval
TOP_K=5

# ── Admin dashboard ──────────────────────────────────────────────────────────
# REQUIRED. The app refuses to start with empty values when ENVIRONMENT=production
# and additionally rejects passwords <12 chars or on a small common-password
# blocklist. Pick something strong.
ADMIN_USERNAME=
ADMIN_PASSWORD=
# How long an admin login is valid (hours). Sessions are persisted in MySQL,
# so they survive backend restarts and work across multiple uvicorn workers.
ADMIN_TOKEN_TTL_HOURS=8

# MySQL — user accounts (create database `course_copilot` or let the SQL file run first)
# Local dev: 127.0.0.1 + your MySQL user. Docker Compose: set MYSQL_HOST=db in compose
# (already set there); optional MYSQL_* overrides live in project root .env for compose.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=course_copilot

# ── Stripe (test mode) ────────────────────────────────────────────────────────
# Leave blank to disable the pricing page / payment routes.
# Dashboard → Developers → API keys. Use test keys (sk_test_... / pk_test_...).
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# From: stripe listen --forward-to localhost:8000/api/payments/webhook
# (the CLI prints `Your webhook signing secret is whsec_...`).
STRIPE_WEBHOOK_SECRET=
# Price IDs from Dashboard → Products. Create two products (Regular, Advanced),
# each with a monthly + yearly recurring price. Copy the `price_...` ids here.
STRIPE_PRICE_REGULAR_MONTHLY=
STRIPE_PRICE_REGULAR_YEARLY=
STRIPE_PRICE_ADVANCED_MONTHLY=
STRIPE_PRICE_ADVANCED_YEARLY=
# Where Stripe redirects after checkout (must match the URL users see in the browser).
FRONTEND_URL=http://localhost:3000

# Google Sign-In — Web Client ID (same string as VITE_GOOGLE_CLIENT_ID in project root .env)
GOOGLE_OAUTH_CLIENT_ID=

# Facebook Login (Meta Developer → your app)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Microsoft Sign-In — Application (client) ID from Microsoft Entra ID
# (Azure portal → App registrations → your app → Overview). Same value as
# VITE_MICROSOFT_CLIENT_ID in project root .env.
MICROSOFT_CLIENT_ID=

# ── SMTP (password reset codes, study & upgrade reminder emails) ─────────────
# The address users see in their inbox is SMTP_FROM_EMAIL (not SMTP_USERNAME
# unless you leave FROM blank — don’t). For Gmail, create an App Password on
# the Laboracle mailbox and use that account for both USERNAME and FROM.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=laboraclee@gmail.com
SMTP_PASSWORD=
SMTP_FROM_EMAIL=laboraclee@gmail.com
SMTP_FROM_NAME=Laboracle

# Set to false when Gemini 2.5 Pro should be selectable again.
GEMINI_PRO_TEMPORARILY_DISABLED=true
